{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "allowJs": false,
    "noImplicitAny": true,
    "noEmit": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "target": "esnext",
    "module": "esnext",
    "lib": ["DOM", "ESNext"],
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["web/*"],
      "/gadget/app/*": ["*"]
    }
  },
  "exclude": ["node_modules", ".gadget"]
}
